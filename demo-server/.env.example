# ACRCloud identify credentials — copy to .env and fill in from the ACRCloud
# console (Projects → your project → host / access key / access secret).
# NEVER commit the real .env.
ACR_HOST=identify-eu-west-1.acrcloud.com
ACR_ACCESS_KEY=
ACR_ACCESS_SECRET=

# Server port (the demo-app Vite proxy expects 5177)
PORT=5177

# Set to 1 ONLY for local pipeline testing without real credentials.
# Returns a canned match so the UI flow can be exercised end-to-end.
# Must be unset/0 in the meeting: mock results must never be presented as real.
ACR_MOCK=0
